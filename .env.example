# SriVoraTech Database Environment Configuration

# 1. Google Sheets Integration
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# 2. Firebase Realtime Database / Firestore Integration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=srivoratech-ratings.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://srivoratech-ratings-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=srivoratech-ratings
VITE_FIREBASE_STORAGE_BUCKET=srivoratech-ratings.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# 3. MongoDB Atlas Database (Primary Persistent Storage)
MONGODB_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/srivoratech?retryWrites=true&w=majority

# 4. Supabase Cloud Database Integration (Optional)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
